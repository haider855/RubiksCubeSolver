{
  "name": "rubiks-cube-solver",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "verify:cube": "tsc -p tsconfig.verify.json && node .verify-dist/tests/cubeEngineVerification.js",
    "verify:validation": "tsc -p tsconfig.verify.json && node .verify-dist/tests/validationVerification.js",
    "verify:white-cross": "tsc -p tsconfig.verify.json && node .verify-dist/tests/whiteCrossVerification.js",
    "verify:white-corners": "tsc -p tsconfig.verify.json && node .verify-dist/tests/whiteCornersVerification.js",
    "verify:middle-layer": "tsc -p tsconfig.verify.json && node .verify-dist/tests/middleLayerVerification.js",
    "verify:yellow-cross": "tsc -p tsconfig.verify.json && node .verify-dist/tests/yellowCrossVerification.js",
    "verify:orient-yellow-corners": "tsc -p tsconfig.verify.json && node .verify-dist/tests/orientYellowCornersVerification.js",
    "verify:position-yellow-corners": "tsc -p tsconfig.verify.json && node .verify-dist/tests/positionYellowCornersVerification.js",
    "verify:position-yellow-edges": "tsc -p tsconfig.verify.json && node .verify-dist/tests/positionYellowEdgesVerification.js",
    "verify:solve-cube": "tsc -p tsconfig.verify.json && node .verify-dist/tests/solveCubeVerification.js"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
